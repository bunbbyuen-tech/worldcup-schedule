# This app needs NO API key for match data (openfootball is public-domain, keyless).
#
# Secrets are only needed for Phase 2 — shared "starred teams" via a Google Sheet.
# When you set that up, copy this file to  .streamlit/secrets.toml  (git-ignored),
# or on Streamlit Cloud paste these lines into the app's Secrets panel.
#
# [connections.gsheets]
# spreadsheet = "https://docs.google.com/spreadsheets/d/.../edit"
# type = "service_account"
# project_id = "..."
# private_key = "..."
# client_email = "...@...iam.gserviceaccount.com"
# (full template: https://docs.streamlit.io/develop/tutorials/databases/private-gsheet)
